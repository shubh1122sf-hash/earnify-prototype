
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Set the default database to SQLite for local development.
// For production (e.g., with Vercel Postgres), you'll set the DATABASE_URL
// environment variable to point to your Postgres instance.
datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  image     String?
  scores    Score[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Score {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Int
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}
